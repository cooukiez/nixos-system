{
  # core
  enabled = false;
  position = "right";
  dockType = "attached";
  size = 1;
  onlySameOutput = true;
  monitors = [ ];
  sitOnFrame = false;

  # appearance
  backgroundOpacity = 0.75;
  deadOpacity = 0.3;
  colorizeIcons = false;

  displayMode = "auto_hide";
  animationSpeed = 1;
  floatingRatio = 1;

  # app management
  showLauncherIcon = false;

  pinnedApps = [ ];
  pinnedStatic = false;
  groupApps = true;
  groupContextMenuMode = "extended";
  groupClickAction = "list";

  # indicators
  showDockIndicator = true;
  indicatorThickness = 3;
  indicatorColor = "primary";
  indicatorOpacity = 0.6;
  indicatorStyle = "dots";
  inactiveIndicators = false;
}
